    "load testing",
    "performance test",
    "performance testing"
  ],
  "type": "module",
  "bin": {
    "gatling-mcp-server": "target/index.js"
  },
  "files": [
    "target"
  ],
  "main": "target/index.js",
  "scripts": {
    "clean": "rimraf /target",
    "build": "tsc && chmod +x target/index.js",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "start": "npm run build && ./target/index.js"
  },
  "dependencies": {
    "@actions/http-client": "4.0.0",
    "@amplitude/analytics-node": "1.5.45",
    "@modelcontextprotocol/sdk": "1.27.1",
    "uuid": "13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.12.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  }
}
