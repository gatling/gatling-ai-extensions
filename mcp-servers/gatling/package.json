{
  "name": "@gatling.io/gatling-mcp-server",
  "version": "0.1.10",
  "license": "Apache-2.0",
  "homepage": "https://gatling.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gatling/gatling-ai-extensions.git"
  },
  "bugs": "https://github.com/gatling/gatling/issues",
  "keywords": [
    "gatling",
    "mcp",
    "model context protocol",
    "ai",
